<div class="products-header">
  <h1>Productos</h1>
  <a href="/products/new" class="btn btn-primary">+ Nuevo Producto</a>
</div>

{{#if products.length}}
<div class="products-grid">
  {{#each products}}
  <div class="card product-card">
    <div class="card-img">
      <img src="/uploads/{{this.imagen}}" alt="{{this.nombre}}" onerror="this.src='/img/placeholder.svg'">
    </div>
    <div class="card-body">
      <h3 class="card-title">{{this.nombre}}</h3>
      <p class="card-price">${{this.precio}}</p>
      <p class="card-desc">{{this.descripcion}}</p>
      <div class="card-actions">
        <a href="/products/{{this._id}}/edit" class="btn btn-sm btn-secondary">Editar</a>
        <form action="/products/{{this._id}}?_method=DELETE" method="POST" class="inline" onsubmit="return confirm('¿Eliminar este producto?')">
          <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
        </form>
      </div>
    </div>
  </div>
  {{/each}}
</div>
{{else}}
<div class="empty-state">
  <div class="empty-icon">📦</div>
  <h2>No hay productos</h2>
  <p>Crea tu primer producto para empezar</p>
  <a href="/products/new" class="btn btn-primary">Crear producto</a>
</div>
{{/if}}
