<div class="login-page">
  <div class="login-card">
    <div class="login-header">
      <h1>CRTX Store</h1>
      <p>Inicia sesión para continuar</p>
    </div>

    {{#if errors}}
    <div class="login-errors">
      {{#each errors}}
      <div class="form-error">{{this}}</div>
      {{/each}}
    </div>
    {{/if}}

    <form action="/auth/login" method="POST" class="login-form">
      <div class="form-group">
        <label for="username">Usuario</label>
        <input type="text" id="username" name="username" class="input" value="{{username}}" placeholder="Tu nombre de usuario" autofocus>
      </div>

      <div class="form-group">
        <label for="password">Contraseña</label>
        <input type="password" id="password" name="password" class="input" placeholder="Tu contraseña">
      </div>

      <button type="submit" class="btn btn-primary btn-full">Entrar</button>
    </form>
  </div>
</div>
