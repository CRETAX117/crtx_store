{{#if success}}
<div class="flash flash-success">
  <span>{{success}}</span>
  <button class="flash-close" onclick="this.parentElement.remove()">×</button>
</div>
{{/if}}
{{#if error}}
<div class="flash flash-error">
  <span>{{error}}</span>
  <button class="flash-close" onclick="this.parentElement.remove()">×</button>
</div>
{{/if}}
